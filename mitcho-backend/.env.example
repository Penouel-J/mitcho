# ── Base de données ─────────────────────────────────────────────────
# SQLite (par défaut, aucune installation requise)
DATABASE_URL=sqlite+aiosqlite:///./mitcho.db

# ── Sécurité JWT ────────────────────────────────────────────────────
SECRET_KEY=changez_cette_cle_par_une_valeur_aleatoire_longue
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── IA — Groq API ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email — Resend ──────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=alertes@mitchobenin.org
FROM_NAME=MITCHÔ Alertes

# ── RAG — ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=mitcho_knowledge

# ── Données ─────────────────────────────────────────────────────────
GDELT_MAX_RECORDS=50
WFP_COUNTRY_CODE=BEN

# ── CORS (origines autorisées séparées par virgule) ─────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
